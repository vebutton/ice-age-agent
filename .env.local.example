# Copy to .env.local (gitignored) and fill in real values.
# Then before starting Claude Code in this project:
#   source .env.local && claude

# Slack bot token (xoxb-...) for korotovsky/slack-mcp-server.
# Token comes from the "Sage" Slack app in the work Slack workspace.
export SLACK_MCP_XOXB_TOKEN="xoxb-REPLACE-ME"

# AgentMail API key — Sage's own (separate from Robin's).
# Generate on agentmail.to, scoped to Sage's dedicated inbox.
# Retrieval is on-demand only (no auto-polling). Used via Bash+curl
# against https://api.agentmail.to/v0 (Bearer auth).
export AGENTMAIL_API_KEY="REPLACE-ME"
